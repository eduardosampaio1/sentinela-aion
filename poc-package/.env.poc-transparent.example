# AION POC Transparent — Variáveis de ambiente
# ============================================================
# Copie este arquivo para .env antes de subir o stack:
#   cp .env.poc-transparent.example .env
#
# Edite TODOS os valores marcados com <...> antes de usar.
# Depois rode: docker compose -f docker-compose.poc-transparent.yml up -d
# ============================================================
#
# IMPORTANTE: este modo faz o AION CHAMAR o LLM com a credencial do
# cliente. Discuta com CISO e jurídico antes de usar em ambiente
# restritivo. Para banco/telecom/CISO duro, prefira POC Decision-Only
# (.env.poc-decision.example + docker-compose.poc-decision.yml).
# ============================================================

# ── Runtime (obrigatórios) ────────────────────────────────────
# Licença JWT fornecida pela Baluarte para o ambiente de POC.
AION_LICENSE=<jwt-fornecido-pela-baluarte>

# Chave admin humana. Formato: "<chave>:<role>".
# Roles válidas: admin, operator, analyst, viewer, auditor, security.
AION_ADMIN_KEY=<chave-admin>:admin

# Opcional aqui (este compose não embute o console). Se você for rodar
# o console em paralelo, defina e reaproveite o mesmo valor no .env do
# console (AION_API_KEY). Sem console, deixe vazio.
AION_CONSOLE_PROXY_KEY=

# ── Segurança (obrigatórios em staging/production — F-03/F-12) ─
# HMAC-SHA256 da trilha de auditoria. Gere com: openssl rand -hex 32
AION_SESSION_AUDIT_SECRET=<openssl-rand-hex-32>

# ── Credencial LLM (obrigatória em Transparent) ───────────────
# Cliente abre essa credencial para o AION em troca de integração
# zero-code. AION chama o LLM em nome do cliente.
OPENAI_API_KEY=sk-<sua-chave>
# ANTHROPIC_API_KEY=sk-ant-<sua-chave>
# GEMINI_API_KEY=<sua-chave>

# Provider/modelo padrão usado quando NOMOS não decide outra coisa.
AION_DEFAULT_PROVIDER=openai
AION_DEFAULT_MODEL=gpt-4o-mini

# Para Azure OpenAI / vLLM / Ollama / qualquer OpenAI-compatible:
# AION_DEFAULT_BASE_URL=https://<seu-endpoint>/v1
# AION_DEFAULT_API_KEY=<chave-do-endpoint-customizado>

# ── Profile de deployment (opcional; default = staging) ───────
# Em Transparent, F-36 exige AION_BUDGET_ENABLED=true (já setado no
# compose). Sem isso, uma única request grande pode consumir todo o
# orçamento do cliente com o provider LLM.
# AION_PROFILE=staging

# ── Chave pública Ed25519 (recomendado em production) ─────────
# Em AION_PROFILE=production o boot é abortado se esta env não estiver
# definida. Em staging, fallback dev/test é aceito (com warning).
# AION_LICENSE_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----
# MCowBQYDK2VwAyEA...
# -----END PUBLIC KEY-----
