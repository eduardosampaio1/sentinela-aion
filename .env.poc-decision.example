# AION POC Decision-Only — Variáveis de ambiente
# ============================================================
# Copie este arquivo para .env antes de subir o stack:
#   cp .env.poc-decision.example .env
#
# Edite os valores marcados com <...> antes de usar.
# ============================================================

# ── Runtime (obrigatórios) ────────────────────────────────────
# Licença JWT fornecida pela Baluarte para o ambiente de POC.
AION_LICENSE=<jwt-fornecido-pela-baluarte>

# Chave de autenticação admin — usada nos endpoints /v1/admin/*
# Formato: "<valor>:<role>". Use "poc" como role para POC.
AION_ADMIN_KEY=chave-poc:admin

# ── Console (opcional) ────────────────────────────────────────
# Segredo para assinar sessões do console Next.js.
# Se vazio, o console gera um segredo aleatório na inicialização.
# Em produção: use um valor longo e aleatório (mínimo 32 chars).
CONSOLE_AUTH_SECRET=
