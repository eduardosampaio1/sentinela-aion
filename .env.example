# === AION — Motor Realtime do Sentinela (AI Control Plane) ===

# Modo de falha: open (passthrough se AION falhar) | closed (bloqueia)
AION_FAIL_MODE=open

# Kill switch global (botão nuclear)
AION_SAFE_MODE=false

# Porta do AION
AION_PORT=8080

# Auth para endpoints admin (comma-separated para rotação: "key1,key2")
AION_ADMIN_KEY=

# === LLM Default (usado quando NOMOS nao esta ativo) ===
AION_DEFAULT_PROVIDER=openai
AION_DEFAULT_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-...

# === Providers adicionais (usados pelo NOMOS) ===
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...

# === Redis (opcional — fallback para cache local) ===
# REDIS_URL=rediss://default:token@host:6379

# === ARGOS integration (opcional) ===
# ARGOS_TELEMETRY_URL=http://localhost:8000/v1/telemetry

# === Modulos ativos ===
AION_ESTIXE_ENABLED=true
AION_NOMOS_ENABLED=false
AION_METIS_ENABLED=true

# === ESTIXE config ===
ESTIXE_BYPASS_THRESHOLD=0.85
ESTIXE_EMBEDDING_MODEL=all-MiniLM-L6-v2

# === Security (POC/Enterprise) ===
# CORS: origens permitidas (comma-separated). Vazio = sem CORS.
# AION_CORS_ORIGINS=http://localhost:3000,https://console.aion.io

# Exigir auth no endpoint /v1/chat/completions (default: false)
# AION_REQUIRE_CHAT_AUTH=false

# Exigir header X-Aion-Tenant (sem fallback para "default")
# AION_REQUIRE_TENANT=false

# Rate limits (por tenant+IP, requests/min)
# AION_CHAT_RATE_LIMIT=100
# AION_ADMIN_RATE_LIMIT=10

# === Multi-tenancy ===
# AION_TENANT_HEADER=X-Aion-Tenant
# AION_DEFAULT_TENANT=default

# === Data retention ===
# Tempo de retencao de telemetria em horas (default: 168 = 7 dias)
# AION_TELEMETRY_RETENTION_HOURS=168

# === NOMOS scoring weights (ajuste fino do roteamento) ===
# NOMOS_WEIGHT_COST=10000
# NOMOS_WEIGHT_FIT=0.5
# NOMOS_WEIGHT_LATENCY=1.0
# NOMOS_WEIGHT_RISK_PENALTY=50.0
# NOMOS_WEIGHT_CAPABILITY_MISS=20.0
