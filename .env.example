# === AION — Motor Realtime do Sentinela (AI Control Plane) ===
#
# MODO DE OPERAÇÃO
# ────────────────
# poc_decision    → AION decide, cliente chama o LLM (recomendado para enterprise)
# poc_transparent → AION proxy completo, chama o LLM do cliente
# full_transparent → produção como gateway completo
# decision_only   → produção em modo decisão pura
#
# AION_MODE é informacional — exposto no /health para visibilidade no console.
# Não altera o comportamento do pipeline (os módulos é que controlam o comportamento).
AION_MODE=poc_transparent

# === LICENÇA (obrigatório) ===
# Opção A (recomendada): coloque o arquivo aion.lic na mesma pasta do docker-compose.yml
#   O AION detecta automaticamente o arquivo — nenhuma variável necessária.
# Opção B: cole o JWT diretamente aqui:
# AION_LICENSE=eyJhbGciOiJFZERTQSIsInR5cCI6IkpXVCJ9...

# === AUTH (obrigatório) ===
# Formato: "chave:role" — roles: admin | operator | viewer | analyst | security | auditor
# Múltiplas chaves para rotação: "chave1:admin,chave2:operator"
AION_ADMIN_KEY=

# === SERVIDOR ===
AION_FAIL_MODE=open        # open = degrada graciosamente | closed = bloqueia em falha
AION_SAFE_MODE=false       # true = kill switch: passthrough total, desativa todos os módulos
AION_PORT=8080

# === SEGREDO DE AUDITORIA ===
# Assina a trilha de auditoria com HMAC-SHA256 (tamper evidence).
# Gere com: openssl rand -hex 32
AION_SESSION_AUDIT_SECRET=

# === MÓDULOS ===
# POC Transparent: ESTIXE detecta PII e bloqueia, NOMOS roteia modelo ideal, METIS otimiza contexto.
AION_ESTIXE_ENABLED=true
AION_NOMOS_ENABLED=true
AION_METIS_ENABLED=true

# === LLM — apenas para POC Transparent e Full ===
# Não necessário no POC Decision-Only (AION não chama LLM neste modo)
AION_DEFAULT_PROVIDER=openai
AION_DEFAULT_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...

# Para Azure, vLLM, Ollama ou qualquer endpoint OpenAI-compatible:
# AION_DEFAULT_BASE_URL=https://cliente.openai.azure.com/...
# AION_DEFAULT_API_KEY=...

# === REDIS (recomendado) ===
# Em implantação real: Redis do próprio cliente.
# Baluarte não acessa o Redis do cliente.
# REDIS_URL=rediss://default:token@host:6379

# === ESTIXE ===
ESTIXE_BYPASS_THRESHOLD=0.85
ESTIXE_EMBEDDING_MODEL=all-MiniLM-L6-v2

# === TELEMETRIA SENTINELA (opcional) ===
# Persiste decisões e eventos de auditoria no painel Sentinela.
# Apenas metadados (tenant, decisão, custo, latência) — nunca conteúdo de mensagens.
# AION_SUPABASE_URL=https://vtyckndcjczxqcqacsby.supabase.co
# AION_SUPABASE_SERVICE_ROLE_KEY=

# === TELEMETRIA EXTERNA — Shadow Mode apenas ===
# NÃO configurar na POC. Zero dados saem do ambiente do cliente.
# Ativar apenas após DPA assinado com Baluarte (Shadow Mode opt-in).
# ARGOS_TELEMETRY_URL=
# AION_CONTRIBUTE_GLOBAL_LEARNING=false

# === COLLECTIVE (editorial) ===
# Phase 0: catálogo YAML local + lifecycle administrativo.
# Installed policies NÃO são aplicadas no runtime nesta fase.
# AION_COLLECTIVE_ENABLED=true

# === SEGURANÇA ===
# Origens permitidas para CORS (comma-separated). Vazio = sem CORS.
# AION_CORS_ORIGINS=http://localhost:3000,https://console.aion.io

# Exigir auth no /v1/chat/completions
# AION_REQUIRE_CHAT_AUTH=false

# Exigir header X-Aion-Tenant (sem fallback para "default")
# AION_REQUIRE_TENANT=false

# Rate limits (por tenant+IP, requests/min)
# AION_CHAT_RATE_LIMIT=100
# AION_ADMIN_RATE_LIMIT=10

# === MULTI-TENANCY ===
# AION_TENANT_HEADER=X-Aion-Tenant
# AION_DEFAULT_TENANT=default

# === DADOS ===
# Tempo de retenção de telemetria em horas (default: 168 = 7 dias)
# AION_TELEMETRY_RETENTION_HOURS=168

# === NOMOS — pesos de scoring (ajuste fino) ===
# NOMOS_WEIGHT_COST=10000
# NOMOS_WEIGHT_FIT=0.5
# NOMOS_WEIGHT_LATENCY=1.0
# NOMOS_WEIGHT_RISK_PENALTY=50.0
# NOMOS_WEIGHT_CAPABILITY_MISS=20.0
