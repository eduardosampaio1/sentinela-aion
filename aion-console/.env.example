# AION Console — Environment Variables
# Copy to .env.local and fill in your values.
# Never commit .env.local to git.

# ── Server-side only (no NEXT_PUBLIC_ prefix — never sent to browser) ─────────

# URL base do backend AION (usada pelo proxy server-side /api/proxy)
AION_API_URL=http://localhost:8080

# Chave de servico do Console — identidade de SISTEMA, nao de pessoa humana.
# Papel obrigatorio: "console_proxy" (nao use "admin" — isso bypassa o RBAC por usuario).
# O AION aplica RBAC usando o papel do ator SSO (X-Aion-Actor-Role), nao esta chave.
# Esta chave apenas autentica a origem confiavel; quem autoriza e o papel do usuario logado.
#
# Formato: "chave:papel" conforme AION_ADMIN_KEY no backend
# Correto:  "console-service-prod-abc123:console_proxy"
# ERRADO:   "qualquer-chave:admin"  (bypassa o RBAC por papel de usuario)
# NUNCA use NEXT_PUBLIC_AION_API_KEY (exporia a chave no bundle do browser).
AION_API_KEY=

# ── Client-side (NEXT_PUBLIC_ prefix — visível no browser bundle) ─────────────

# Tenant padrão usado em todas as requisições (header X-Aion-Tenant)
# Não é sensível — apenas identifica o contexto desta instância.
NEXT_PUBLIC_AION_TENANT=default

# ── Demo mode ─────────────────────────────────────────────────────────────────
# true = força uso de mock data em todas as páginas (sem chamadas ao backend)
# false = tenta backend real; fallback automático para mock se indisponível
NEXT_PUBLIC_DEMO_MODE=false

# ── Autenticação (NextAuth v5) ─────────────────────────────────────────────────
# Segredo para assinar cookies de sessão (gere com: openssl rand -hex 32)
AUTH_SECRET=

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Console GCP → APIs & Serviços → Credenciais → OAuth 2.0
# Redirect URI: https://seu-dominio/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Microsoft Entra ID (Azure AD) ──────────────────────────────────────────────
# Azure Portal → App registrations → Authentication
# Redirect URI: https://seu-dominio/api/auth/callback/microsoft-entra-id
AUTH_ENTRA_ID=
AUTH_ENTRA_SECRET=
AUTH_ENTRA_TENANT_ID=

# ── Mapeamento de papéis (RBAC) ────────────────────────────────────────────────
# AION_ROLE_MAP: pares email:papel separados por vírgula
# Papéis: admin | operator | analyst | viewer | auditor | security
# Exemplo: "admin@empresa.com:admin,maria@empresa.com:operator,joao@empresa.com:viewer"
AION_ROLE_MAP=

# Emails que recebem papel "admin" automaticamente (sem precisar de AION_ROLE_MAP)
# Exemplo: "cto@empresa.com,devops@empresa.com"
AION_ADMIN_EMAILS=

# Papel padrão para qualquer usuário autenticado que não esteja no AION_ROLE_MAP
# Padrão: viewer (leitura apenas) — mude para "operator" se todos forem operadores
AION_DEFAULT_ROLE=viewer

# ── Dev bypass (NUNCA ATIVAR EM PRODUÇÃO) ─────────────────────────────────────
# O proxy /api/proxy/* faz fail-closed: requests sem sessão NextAuth recebem 401.
# Para rodar o console em dev sem configurar OAuth, defina ambos:
#   NODE_ENV=development (qualquer coisa que NÃO seja "production")
#   AION_PROXY_DEV_BYPASS=true
# Se faltar qualquer um dos dois, o gate continua ativo.
# AION_PROXY_DEV_BYPASS=false
