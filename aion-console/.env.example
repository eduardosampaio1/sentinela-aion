# AION Console — Environment Variables
# Copy to .env.local and fill in your values.
# Never commit .env.local to git.

# ── Server-side only (no NEXT_PUBLIC_ prefix — never sent to browser) ─────────

# URL base do backend AION (usada pelo proxy server-side /api/proxy)
AION_API_URL=http://localhost:8080

# Chave de API para autenticação — injetada server-side pelo proxy.
# NUNCA use NEXT_PUBLIC_AION_API_KEY (exporia a chave no bundle do browser).
# Formato: "chave:papel" conforme configurado em AION_ADMIN_KEY no backend
# Exemplos: "dev-key-admin:admin" | "viewer-key:viewer"
AION_API_KEY=

# ── Client-side (NEXT_PUBLIC_ prefix — visível no browser bundle) ─────────────

# Tenant padrão usado em todas as requisições (header X-Aion-Tenant)
# Não é sensível — apenas identifica o contexto desta instância.
NEXT_PUBLIC_AION_TENANT=default

# ── Demo mode ─────────────────────────────────────────────────────────────────
# true = força uso de mock data em todas as páginas (sem chamadas ao backend)
# false = tenta backend real; fallback automático para mock se indisponível
NEXT_PUBLIC_DEMO_MODE=false
